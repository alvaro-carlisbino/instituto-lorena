VITE_DATA_MODE=mock
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Mesmo valor que CRM_WEBHOOK_SECRET na Edge Function (so para testar no Admin Lab)
# VITE_CRM_WEBHOOK_SECRET=
# Mesmo valor que MANYCHAT_CRM_SECRET na Edge Function crm-manychat-webhook
# VITE_MANYCHAT_CRM_SECRET=
#
# Edge (Supabase Secrets), opcional — CRM chama API ManyChat após IA (setCustomField + sendFlow):
# MANYCHAT_API_KEY=
# MANYCHAT_DM_FIELD_ID=14539456
# MANYCHAT_DM_FLOW_NS=content20260430143025_638461
# MANYCHAT_SEND_FLOW_MESSAGE_TAG=
# MANYCHAT_PUSH_DISABLED=true
# MANYCHAT_ASYNC_ACK=false   # resposta síncrona com reply no JSON (ManyChat pode dar timeout ~10s)
# Mesmo valor que CRM_AI_INTERNAL_SECRET nas Edge Functions (≥16 caracteres; auto-reply IA)
# CRM_AI_INTERNAL_SECRET=
