VITE_DATA_MODE=mock
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Mesmo valor que CRM_WEBHOOK_SECRET na Edge Function (so para testar no Admin Lab)
# VITE_CRM_WEBHOOK_SECRET=
# Mesmo valor que MANYCHAT_CRM_SECRET na Edge Function crm-manychat-webhook
# VITE_MANYCHAT_CRM_SECRET=
#
# Edge (Supabase Secrets), opcional — CRM chama API ManyChat após IA (setCustomField + sendFlow):
# MANYCHAT_API_KEY=
# MANYCHAT_DM_FIELD_ID=14539456
# MANYCHAT_DM_FLOW_NS=content20260430143025_638461
# MANYCHAT_SEND_FLOW_MESSAGE_TAG=         # ex.: HUMAN_AGENT se Meta/ManyChat exigir tag no sendFlow
# MANYCHAT_PUSH_BEFORE_FLOW_DELAY_MS=200   # espera ms entre setCustomField e sendFlow (0–10000; omissão 200)
# MANYCHAT_SEND_FLOW_MAX_ATTEMPTS=2       # tentativas sendFlow (1–5; omissão 2)
# MANYCHAT_PUSH_SKIP_SEND_FLOW=false      # true = só preenche ENVIAR-DM; dispara o flow no próprio ManyChat (evita sendFlow duplicado na API)
# MANYCHAT_WA_DM_FIELD_ID=
# MANYCHAT_WA_DM_FLOW_NS=
# MANYCHAT_WA_SEND_FLOW_MESSAGE_TAG=
# MANYCHAT_PUSH_DISABLED=true
# MANYCHAT_ASYNC_ACK=false   # força síncrono. Com MANYCHAT_API_KEY omitido: já é síncrono por omissão (reply no JSON).
# Mesmo valor que CRM_AI_INTERNAL_SECRET nas Edge Functions (≥16 caracteres; auto-reply IA)
# CRM_AI_INTERNAL_SECRET=
# WhatsApp auto-reply: milissegundos antes de enviar a DM após a IA (0 = sem espera; omissão ~0,4–0,9 s)
# WHATSAPP_AI_TYPING_DELAY_MS=0
# Se o modelo falhar ou vier resposta vazia, envia este texto (≥8 caracteres). Omissão: mensagem fixa em pt-BR.
# CRM_AI_FALLBACK_MESSAGE_PT=
# Retries ao chamar crm-ai-assistant (1–5; omissão 3)
# CRM_AI_INVOKE_ATTEMPTS=3

# --- Frete (Melhor Envio → Correios PAC/SEDEX) — bot de vendas Tricopill ---
# Token Bearer do painel Melhor Envio (app/token c/ escopo shipping-calculate). OBRIGATÓRIO p/ cotar.
# MELHOR_ENVIO_TOKEN=
# true = sandbox.melhorenvio.com.br (testes); qualquer outra coisa = produção
# MELHOR_ENVIO_SANDBOX=false
# CEP de origem (de onde sai a encomenda). Omissão: 87014180 (clínica Maringá)
# MELHOR_ENVIO_FROM_CEP=87014180
# Identificação OBRIGATÓRIA pela Melhor Envio: "App Nome (email@dominio)"
# MELHOR_ENVIO_USER_AGENT=Instituto Lorena CRM (seu-email@dominio.com)
# IDs de serviço a cotar. Omissão "1,2" = Correios PAC e SEDEX
# MELHOR_ENVIO_SERVICES=1,2
# Caixa padrão única (todos os kits) — AJUSTE com as medidas reais do pacote:
# FRETE_BOX_WEIGHT_KG=0.5
# FRETE_BOX_LENGTH_CM=20
# FRETE_BOX_WIDTH_CM=15
# FRETE_BOX_HEIGHT_CM=10
# Valor segurado opcional em centavos (omissão 0 = sem seguro)
# FRETE_INSURANCE_CENTS=0
